#!/usr/bin/env expect
# Drive the pty-wrapped terminal:
#   - system prompt entry
#   - real shell command (echo)
#   - persistent shell state (set var, then read it back)
#   - a stdin-reading command does not hang (/dev/null redirect)
#   - a hung command is interrupted and the shell recovers
#   - unknown command -> mock LLM fallback
set timeout 15
log_user 0

# Short timeout so the hung-command recovery case runs quickly.
set env(MT_TIMEOUT_SECS) 2

spawn ./target/debug/mock-terminal
expect {
    "Type one or more lines" { }
    timeout { puts "FAIL: system-prompt banner not seen"; exit 1 }
}

send "Be terse.\r"
send "\r"

expect {
    "shell commands run for real" { puts "PASS: REPL banner shown" }
    timeout { puts "FAIL: REPL banner not seen"; exit 1 }
}
expect "$ "

# Real shell command
send "echo hello-from-shell\r"
expect {
    "hello-from-shell" { puts "PASS: real shell executed echo" }
    timeout { puts "FAIL: echo output not seen"; exit 1 }
}

expect "$ "
# Persistent state across commands
send "MYVAR=persistent-value\r"
expect "$ "
send "echo \"\$MYVAR\"\r"
expect {
    "persistent-value" { puts "PASS: shell state persists across commands" }
    timeout { puts "FAIL: MYVAR did not persist"; exit 1 }
}

expect "$ "
# A command that reads stdin must not hang (gets EOF from /dev/null).
send "cat\r"
expect {
    "$ " { puts "PASS: stdin-reading command did not hang" }
    timeout { puts "FAIL: cat hung"; exit 1 }
}

# A genuinely hung command is killed on timeout; the shell must stay usable.
send "sleep 30\r"
expect {
    "interrupted" { puts "PASS: hung command interrupted on timeout" }
    timeout { puts "FAIL: hung command not interrupted"; exit 1 }
}
expect "$ "
send "echo back-after-hang\r"
expect {
    "back-after-hang" { puts "PASS: shell recovered after hang" }
    timeout { puts "FAIL: shell wedged after hang"; exit 1 }
}
expect "$ "

# Manual Ctrl-C must interrupt a running command well before the timeout.
send "sleep 30\r"
# Wait for the command to actually start before interrupting it.
expect "sleep 30"
sleep 1
send "\x03"
expect {
    "interrupted" { puts "PASS: Ctrl-C interrupted a running command" }
    timeout { puts "FAIL: Ctrl-C did not interrupt"; exit 1 }
}
expect "$ "
send "echo back-after-ctrlc\r"
expect {
    "back-after-ctrlc" { puts "PASS: shell recovered after Ctrl-C" }
    timeout { puts "FAIL: shell wedged after Ctrl-C"; exit 1 }
}
expect "$ "

# Interactive passthrough: ':cat' runs cat attached to the terminal; it echoes
# typed input, and Ctrl-D exits it and returns to capture mode.
send ":cat\r"
sleep 1
send "echo-through-cat\r"
expect {
    "echo-through-cat" { puts "PASS: interactive passthrough forwarded I/O" }
    timeout { puts "FAIL: passthrough produced no output"; exit 1 }
}
send "\x04"
expect "$ "
send "echo back-after-passthrough\r"
expect {
    "back-after-passthrough" { puts "PASS: capture mode resumed after passthrough" }
    timeout { puts "FAIL: capture mode broken after passthrough"; exit 1 }
}

expect "$ "
# Unknown command -> LLM fallback
send "totally-not-a-real-command-xyz\r"
expect {
    "asking the LLM" { puts "PASS: fallback triggered on exit 127" }
    timeout { puts "FAIL: fallback not triggered"; exit 1 }
}
expect {
    -re "« .*Be terse" { puts "PASS: mock reply includes system prompt" }
    -re "« " { puts "PASS: mock reply emitted (no system match)" }
    timeout { puts "FAIL: no mock reply"; exit 1 }
}

expect "$ "
send "/exit\r"
expect eof
puts "PASS: clean exit"
