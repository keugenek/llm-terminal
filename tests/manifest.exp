#!/usr/bin/env expect
# End-to-end for `open <manifest>`:
#   - a LOCAL manifest auto-confirms (no prompt) and runs setup + run
#   - `--confirm` forces the gate: "y" runs, "n" aborts
set timeout 15
log_user 0
set env(MT_TRAJECTORY_DIR) /tmp/til-manifest-test

# Write a small manifest with a setup command and a non-interactive run.
set f /tmp/mt-session.json
set fh [open $f w]
puts $fh "{ \"name\": \"demo\", \"system_prompt\": \"accept reads and tests\", \"setup\": \[\"echo setup-ran\"\], \"run\": \"echo run-ran\" }"
close $fh

# --- local auto-confirm path (no prompt, no keystroke) ---
spawn ./target/debug/mock-terminal open $f
expect {
    "SESSION TO LAUNCH" { puts "PASS: session card rendered" }
    timeout { puts "FAIL: no card"; exit 1 }
}
expect {
    "auto-confirmed" { puts "PASS: local manifest auto-confirmed (no prompt)" }
    "Launch this session?" { puts "FAIL: local manifest still prompted"; exit 1 }
    timeout { puts "FAIL: no auto-confirm"; exit 1 }
}
expect {
    "setup-ran" { puts "PASS: setup ran" }
    timeout { puts "FAIL: setup did not run"; exit 1 }
}
expect {
    "run-ran" { puts "PASS: run executed" }
    timeout { puts "FAIL: run did not execute"; exit 1 }
}
expect "$ "
send "/exit\r"
expect eof

# --- --confirm gate, accept ---
spawn ./target/debug/mock-terminal open $f --confirm
expect "Launch this session?"
send "y\r"
expect {
    "setup-ran" { puts "PASS: --confirm + y runs" }
    timeout { puts "FAIL: --confirm y did not run"; exit 1 }
}
expect "$ "
send "/exit\r"
expect eof

# --- --confirm gate, abort ---
spawn ./target/debug/mock-terminal open $f --confirm
expect "Launch this session?"
send "n\r"
expect {
    "Aborted; nothing was run" { puts "PASS: --confirm + n aborts" }
    "setup-ran" { puts "FAIL: ran despite abort"; exit 1 }
    timeout { puts "FAIL: no abort message"; exit 1 }
}
expect eof
puts "PASS: clean"
